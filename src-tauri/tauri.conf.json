{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "watchtower",
  "version": "0.1.0",
  "identifier": "com.dipesh.watchtower",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && npm --prefix sidecar run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "watchtower",
        "width": 1120,
        "height": 760,
        "minWidth": 900,
        "minHeight": 640,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": [
      "../sidecar/dist/**/*",
      "../sidecar/node_modules/**/*",
      "../sidecar/package.json",
      "../sidecar/schemas/**/*"
    ],
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
