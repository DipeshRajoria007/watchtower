{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["status", "summary", "prUrl", "branch", "tests"],
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "const": "success"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "prUrl": {
      "type": "string",
      "pattern": "^https://github\\.com/.+"
    },
    "branch": {
      "type": "string",
      "pattern": "^codex/"
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
