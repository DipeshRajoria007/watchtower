{
  "type": "object",
  "required": ["approved", "findings", "summaryNotes", "overallSeverity"],
  "properties": {
    "approved": {
      "type": "boolean"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "category", "message", "file", "line"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "category": { "type": "string" },
          "message": { "type": "string" },
          "file": { "type": "string" },
          "line": { "type": "number" },
          "suggestion": { "type": "string" }
        }
      }
    },
    "summaryNotes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "overallSeverity": {
      "type": "string",
      "enum": ["clean", "low", "medium", "high", "critical"]
    }
  },
  "additionalProperties": false
}
