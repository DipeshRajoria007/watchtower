{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["status", "summary", "actions", "prUrl"],
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "failed", "no_action", "needs_clarification"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prUrl": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
