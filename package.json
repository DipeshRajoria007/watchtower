{
  "name": "watchtower",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite --port 1420",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri:dev": "node scripts/run-tauri.mjs dev",
    "tauri:build:mac": "node scripts/run-tauri.mjs build --bundles app,dmg",
    "sidecar:dev": "npm --prefix sidecar run dev",
    "sidecar:test": "npm --prefix sidecar run test",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'sidecar/src/**/*.ts' 'sidecar/tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'sidecar/src/**/*.ts' 'sidecar/tests/**/*.ts'",
    "test": "vitest run --dir src/__tests__",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.33.1",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
